AddKeysToAgent yes

Host *
    Compression yes
    # ForwardX11 yes
    IdentitiesOnly yes
    LogLevel ERROR # Disable warning level logging and reject changed keys
    ServerAliveInterval 45 # Keep connection alive with 45 second pings
    StrictHostKeyChecking no

# Disable control master for tailscale hosts
Match exec "getent hosts %h 2>/dev/null | awk '{print $1}' | grep -q '^100\.'"
    ControlMaster no

Match exec "mkdir -p ~/.ssh/cm"
    ControlMaster auto
    ControlPath ~/.ssh/cm/%r@%n:%p
    ControlPersist yes

Include ~/.ssh-private/config
