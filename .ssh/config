AddKeysToAgent yes

Include ~/.ssh-private/config

Host *
    Compression yes
    IdentitiesOnly yes
    LogLevel ERROR # Disable warning level logging and reject changed keys
    ServerAliveInterval 45 # Keep connection alive with 45 second pings

# Disable control master and host key checking for tailscale hosts
Match exec "tailscale status --active 2>/dev/null | awk '{print $2}' | grep -qx %h"
    ControlMaster no
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

Match exec "mkdir -p ~/.ssh/cm"
    ControlMaster auto
    ControlPath ~/.ssh/cm/%r@%n:%p
    ControlPersist yes

# Use faster cipher for container to host copies
Host 172.18.0.1
    Ciphers aes128-gcm@openssh.com
